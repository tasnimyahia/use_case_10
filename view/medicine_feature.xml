<odoo>
    <record id="medicine_feature_action_id" model="ir.actions.act_window">
        <field name="name">Pharmacy</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="medicine_feature_view_id" model="ir.ui.view">
        <field name="name">Pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
        <xpath expr="//field[@name='type']" position="after">
            <div class="o_row">
                <label for="classification" class="o_form_label"/>
                <field name="classification" class="o_form_label" widget="radio"/>
            </div>
        </xpath>
    
        <xpath expr="//field[@name='product_tooltip']" position="after">
                <!-- <label for="max_qty_per_invoice" class="oe_inline" groups="pharmacy_application.manager_group_id"/> -->
                <field name="max_qty_per_invoice" string="Max Qauntitiy invoice" class="oe_inline" invisible="classification != 'is_medicine'" groups="pharmacy_application.manager_group_id"/>
                

            </xpath>
            
        </field>
    </record>

</odoo>
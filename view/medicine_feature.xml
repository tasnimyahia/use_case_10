<odoo>
    <record id="medicine_feature_action_id" model="ir.actions.act_window">
        <field name="name">Pharmacy</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="medicine_feature_view_id" model="ir.ui.view">
        <field name="name">Pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
        <xpath expr="//header" position="inside">
                <field name="classification"/>
        </xpath>
        <!-- <xpath expr="//field[@name='available_in_pos']" position="after">
                <group>
                    <field name="is_medicine"/>
                </group>
            </xpath> -->
        <xpath expr="//field[@name='list_price']" position="after">
            <group groups="pharmacy_application.manager_group_id">
                <field name="max_qty_per_invoice" invisible="classification != 'is_medicine'"/>
                
            </group>  
            </xpath>
            
        </field>
    </record>


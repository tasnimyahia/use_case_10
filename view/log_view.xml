<odoo>
    <record id="view_max_qty_log_tree" model="ir.ui.view">
        <field name="name">max.qty.log.tree</field>
        <field name="model">max.qty.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="product_id"/>
                <field name="attempted_qty"/>
                <field name="allowed_qty"/>
                <field name="date"/>
            </list>
        </field>
    </record>

   

    <record id="action_max_qty_log" model="ir.actions.act_window">
        <field name="name">Max Qty Logs</field>
        <field name="res_model">max.qty.log</field>
        <field name="view_mode">list</field>
    </record>
    <menuitem id="menu_max_qty_log"
            name="Max Qty Logs"
            parent="sale.sale_menu_root"
            action="action_max_qty_log"/>
</odoo>